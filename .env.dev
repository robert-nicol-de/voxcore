# ============= ENVIRONMENT VARIABLES =============
# 🚀 DEVELOPMENT (Local)
# Usage: cp .env.dev .env.local
# Database: SQLite (local file)
# Redis: localhost:6379
# LLM: Groq demo key (rate limited)

# Environment identifier
ENV=dev

# ============= DATABASE =============
# Development: SQLite
DATABASE_URL=sqlite:///voxquery.db

# ============= REDIS =============
# Local Redis
REDIS_URL=redis://localhost:6379

# ============= API KEYS =============
# Get from: https://console.groq.com
GROQ_API_KEY=gsk_dev_key_here_limited_rate

# ============= SECURITY =============
# Local dev key (NOT secure, development only)
SECRET_KEY=dev-secret-key-12345-not-secure
JWT_SECRET_KEY=dev-jwt-key-67890-not-secure

# ============= URLS =============
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ============= LOGGING =============
LOG_LEVEL=DEBUG

# ============= FEATURES =============
# Enable debugging features
DEBUG=true
ALLOW_CORS=true
ALLOW_INTROSPECTION=true

# ============= OPTIONAL =============
# Observability (optional for local dev)
DATADOG_API_KEY=not_needed
SENTRY_DSN=not_needed

# ============= NOTES =============
# - This file should be in .gitignore
# - For production, use .env.prod with real credentials
# - Never commit actual secrets
# - Use strong, unique values for SECRET_KEY and JWT_SECRET_KEY
