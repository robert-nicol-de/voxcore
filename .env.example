# VoxCore Environment Configuration
# Copy this file to .env and fill in your actual values
# Never commit .env with real credentials to Git

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE CREDENTIALS
# Each connector .ini file references a credential_key
# Corresponding environment variable should be defined here
# ═══════════════════════════════════════════════════════════════════════════

# Sales Database (sales_db.ini)
# Connector: sales_db
# Type: postgres
# Host: localhost:5432
SALES_DB_PASSWORD=your_secure_password_here

# Finance Database (finance_db.ini)
# Connector: finance_db
# Type: mysql
# Host: 10.0.0.21:3306
FINANCE_DB_PASSWORD=your_finance_password_here

# Human Resources Database (hr_db.ini)
# Connector: hr_db
# Type: postgres
# Host: 10.0.0.15:5432
HR_DB_PASSWORD=your_hr_password_here

# ═══════════════════════════════════════════════════════════════════════════
# JWT & AUTHENTICATION
# ═══════════════════════════════════════════════════════════════════════════

JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=720

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════

VOXCORE_ENV=development
VOXCORE_LOG_LEVEL=INFO
VOXCORE_AUTOSTART_QUERY_WORKER=false

# Optional Postgres-backed metrics database.
# If omitted or unavailable, metrics and inspector routes degrade gracefully.
# METRICS_DB_HOST=localhost
# METRICS_DB_PORT=5432
# METRICS_DB_NAME=voxcore
# METRICS_DB_USER=postgres
# METRICS_DB_PASSWORD=change_me

# Optional Postgres-backed approval queue.
# If omitted or unavailable, approval routes return an unavailable status instead of crashing.
# APPROVAL_DB_HOST=localhost
# APPROVAL_DB_PORT=5432
# APPROVAL_DB_NAME=voxcore
# APPROVAL_DB_USER=postgres
# APPROVAL_DB_PASSWORD=change_me

# ═══════════════════════════════════════════════════════════════════════════
# SECURITY VAULT (Optional)
# For production, use AWS Secrets Manager, HashiCorp Vault, or similar
# ═══════════════════════════════════════════════════════════════════════════

# VAULT_URL=https://vault.example.com
# VAULT_TOKEN=your_vault_token
# VAULT_PATH=secret/voxcore/connectors
