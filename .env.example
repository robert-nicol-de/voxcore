# VoxCore Environment Configuration
# Copy this file to .env and fill in your actual values
# Never commit .env with real credentials to Git

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE CREDENTIALS
# Each connector .ini file references a credential_key
# Corresponding environment variable should be defined here
# ═══════════════════════════════════════════════════════════════════════════

# Sales Database (sales_db.ini)
# Connector: sales_db
# Type: postgres
# Host: localhost:5432
SALES_DB_PASSWORD=your_secure_password_here

# Finance Database (finance_db.ini)
# Connector: finance_db
# Type: mysql
# Host: 10.0.0.21:3306
FINANCE_DB_PASSWORD=your_finance_password_here

# Human Resources Database (hr_db.ini)
# Connector: hr_db
# Type: postgres
# Host: 10.0.0.15:5432
HR_DB_PASSWORD=your_hr_password_here

# ═══════════════════════════════════════════════════════════════════════════
# JWT & AUTHENTICATION
# ═══════════════════════════════════════════════════════════════════════════

JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=720

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════

VOXCORE_ENV=development
VOXCORE_LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════
# SECURITY VAULT (Optional)
# For production, use AWS Secrets Manager, HashiCorp Vault, or similar
# ═══════════════════════════════════════════════════════════════════════════

# VAULT_URL=https://vault.example.com
# VAULT_TOKEN=your_vault_token
# VAULT_PATH=secret/voxcore/connectors
