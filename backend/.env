APP_NAME=VoxQuery
DEBUG=true
ENVIRONMENT=development

# Warehouse (using SQLite for testing)
WAREHOUSE_TYPE=sqlite
WAREHOUSE_HOST=voxquery.db
WAREHOUSE_PORT=3306
WAREHOUSE_USER=test_user
WAREHOUSE_PASSWORD=test_password
WAREHOUSE_DATABASE=voxquery
WAREHOUSE_SCHEMA=public

# LLM Configuration
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:4b
LLM_API_KEY=not-needed-for-ollama
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# LangChain
LANGSMITH_API_KEY=optional
LANGSMITH_PROJECT=voxquery

# Security
SECRET_KEY=test-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Query Execution
QUERY_TIMEOUT_SECONDS=300
MAX_RESULT_ROWS=100000
ENABLE_DRY_RUN=true

# Cost Guards
ENABLE_COST_TRACKING=true
MAX_QUERY_COST_USD=100.0

# API
API_HOST=0.0.0.0
API_PORT=8000
