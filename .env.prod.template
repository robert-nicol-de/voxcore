# ============= ENVIRONMENT VARIABLES =============
# 🔥 PRODUCTION (Live System)
# ⚠️  WARNING: NEVER commit this file to GitHub
# Set all values in Render dashboard environment variables only
# USE STRONG, UNIQUE PASSWORDS

# Environment identifier
ENV=prod

# ============= DATABASE =============
# PostgreSQL in Render
# Format: postgresql://user:password@host:5432/voxquery_prod
# Requirements:
# - SSL required
# - Connection pooling enabled
# - Read-only user for analytics
# - Admin user for operations
# CRITICAL: Different from staging!
DATABASE_URL=${DATABASE_URL}

# ============= REDIS =============
# Upstash Redis or Render Redis
# Format: redis://password@host:port
# Requirements:
# - AUTH required
# - TLS enforced
# - Memory limit: 256MB
# - LRU eviction policy
# CRITICAL: Different from staging!
REDIS_URL=${REDIS_URL}

# ============= API KEYS =============
# Groq API key (production)
# Get from: https://console.groq.com
# Requirements:
# - Higher rate limits
# - Different from staging key
# CRITICAL: Keep secret!
GROQ_API_KEY=${GROQ_API_KEY}

# ============= SECURITY =============
# Encryption and JWT keys (MUST be 32+ random characters)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Requirements:
# - Different from staging
# - Different from dev
# - Stored ONLY in Render dashboard
# - Rotated annually
# CRITICAL: NEVER share or commit!
SECRET_KEY=${SECRET_KEY}
JWT_SECRET_KEY=${JWT_SECRET_KEY}

# ============= URLS =============
# Production URLs (custom domain)
FRONTEND_URL=https://voxquery.com
BACKEND_URL=https://api.voxquery.com

# ============= LOGGING =============
# Production: minimal logging (only errors and warnings)
LOG_LEVEL=WARNING

# ============= FEATURES =============
# Production: strict security
DEBUG=false
ALLOW_CORS=false
ALLOW_INTROSPECTION=false

# ============= OBSERVABILITY =============
# Production monitoring (optional but recommended)
DATADOG_API_KEY=${DATADOG_API_KEY}
SENTRY_DSN=${SENTRY_DSN}

# ============= DATABASE SETTINGS =============
# Connection pool (conservative)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# Query limits (enforce at VoxCore level)
MAX_ROWS_RETURNED=10000
MAX_EXECUTION_TIME_SECONDS=30
MAX_REQUEST_SIZE=10485760

# ============= REDIS SETTINGS =============
# Memory management
REDIS_TTL_DEFAULT=3600
REDIS_MAX_MEMORY=256mb
REDIS_EVICTION_POLICY=allkeys-lru

# ============= RATE LIMITING =============
# Strict in production
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=5000
RATE_LIMIT_PER_DAY=50000

# ============= CACHE SETTINGS =============
# Aggressive caching to reduce load
CACHE_TTL_CHEAP=3600        # 1 hour for cheap queries
CACHE_TTL_MODERATE=300      # 5 minutes for moderate
CACHE_TTL_EXPENSIVE=60      # 1 minute for expensive

# ============= SECURITY SETTINGS =============
# Strict security headers
REQUIRE_HTTPS=true
HSTS_MAX_AGE=31536000
SESSION_TIMEOUT_MINUTES=480
MASK_SENSITIVE_COLUMNS=true
ENFORCE_TENANT_ISOLATION=true
REQUIRE_MFA=false

# ============= COST CONTROL =============
# Monthly cost limits by role
COST_QUOTA_ANALYST=5000
COST_QUOTA_FINANCE=10000
COST_QUOTA_EXECUTIVE=50000

# ============= BACKUP & RECOVERY =============
# Automated by Render, but track in monitoring
BACKUP_RETENTION_DAYS=7
BACKUP_FREQUENCY=daily

# ============= DISASTER RECOVERY =============
# In case of emergency failover
PRIMARY_REGION=us-east
FAILOVER_REGION=us-west

# ============= COMPLIANCE =============
# Audit trail and data retention
AUDIT_LOG_RETENTION_DAYS=90
DATA_RETENTION_POLICY=comply_with_local_law
PII_ENCRYPTION_ENABLED=true

# ============= PERFORMANCE =============
# Auto-scaling settings
MIN_INSTANCES=1
MAX_INSTANCES=5
SCALE_UP_CPU_THRESHOLD=70
SCALE_DOWN_CPU_THRESHOLD=30

# ============= NOTES =============
# 🔥 CRITICAL REMINDERS:
# 
# 1. THIS FILE SHOULD NEVER BE COMMITTED TO GIT
# 2. ALL SECRETS MUST BE IN RENDER DASHBOARD ONLY
# 3. ROTATE SECRETS ANNUALLY
# 4. GENERATE NEW KEYS FOR PROD (not reused from staging)
# 5. ENABLE MFA FOR RENDER DASHBOARD ACCESS
# 6. AUDIT DATABASE PERMISSIONS (least privilege)
# 7. ENABLE DATABASE BACKUPS AND TEST RECOVERY
# 8. MONITOR ALL ENVIRONMENT VARIABLES FOR CHANGES
# 9. ALERT ON UNAUTHORIZED ACCESS ATTEMPTS
# 10. DOCUMENT ALL SECRET ROTATION PROCEDURES
#
# Checklist before deploying to production:
# ✅ All variables set in Render dashboard
# ✅ Secrets are NOT in this file
# ✅ Database URL uses PostgreSQL
# ✅ Redis URL has AUTH and TLS
# ✅ SSL/HTTPS is required
# ✅ Rate limiting is configured
# ✅ Backup is enabled
# ✅ Monitoring is active
# ✅ On-call schedule is ready
# ✅ Runbooks are written
# ✅ Team is trained
