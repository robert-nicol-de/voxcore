# Example environment configuration

# Warehouse Connection
WAREHOUSE_TYPE=snowflake
WAREHOUSE_HOST=xy12345.us-east-1.snowflakecomputing.com
WAREHOUSE_PORT=443
WAREHOUSE_USER=voxquery_user
WAREHOUSE_PASSWORD=your_password_here
WAREHOUSE_DATABASE=analytics
WAREHOUSE_SCHEMA=PUBLIC

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=sk-...
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# LangSmith Tracing (Optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=voxquery

# Security
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Query Execution
QUERY_TIMEOUT_SECONDS=300
MAX_RESULT_ROWS=100000
ENABLE_DRY_RUN=true

# Cost Guards
ENABLE_COST_TRACKING=true
MAX_QUERY_COST_USD=100.0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Debug
DEBUG=false
ENVIRONMENT=development
