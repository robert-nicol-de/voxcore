{
  "name": "voxquery",
  "version": "0.1.0",
  "description": "Turn everyday business questions into SQL",
  "private": true,
  "dependencies": {
    "axios": "^1.6.0",
    "echarts": "^6.0.0",
    "lucide-react": "^0.263.0",
    "plotly.js": "^2.26.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1",
    "reactflow": "^11.11.4",
    "vega": "^5.25.0",
    "vega-embed": "^6.24.0",
    "vega-lite": "^5.16.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^22.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.2.0",
    "vite": "^4.5.0",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "dev": "npx vite",
    "build": "npx vite build",
    "preview": "npx vite preview",
    "prepare": "husky install",
    "lint": "eslint src --ext ts,tsx --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:analytics": "vitest run src/app/widgets/RevenueByRegionWidget.test.tsx src/app/widgets/RevenueByProductWidget.test.tsx src/app/widgets/RevenueByCategoryWidget.test.tsx src/app/widgets/RevenueByCustomerWidget.test.tsx src/app/widgets/RevenueAnomaliesWidget.test.tsx",
    "typecheck:analytics": "tsc --noEmit -p tsconfig.analytics.json"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
