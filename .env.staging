# ============= ENVIRONMENT VARIABLES =============
# 🧪 STAGING (Production Mirror)
# Usage: Set in Render dashboard environment variables
# Database: PostgreSQL (separate instance)
# Redis: Render Redis (separate instance)
# LLM: Production Groq key with higher limits

# Environment identifier
ENV=staging

# ============= DATABASE =============
# NOTE: DO NOT PUT ACTUAL CREDENTIALS IN THIS FILE
# Set DATABASE_URL in Render dashboard instead
# Format: postgresql://user:password@host:5432/voxquery_staging
DATABASE_URL=${DATABASE_URL}

# ============= REDIS =============
# NOTE: DO NOT PUT ACTUAL PASSWORD IN THIS FILE
# Set REDIS_URL in Render dashboard
# Format: redis://password@host:6379
REDIS_URL=${REDIS_URL}

# ============= API KEYS =============
# Set GROQ_API_KEY in Render dashboard
# Use production Groq key with staging label
GROQ_API_KEY=${GROQ_API_KEY}

# ============= SECURITY =============
# Set in Render dashboard (32+ character random strings)
SECRET_KEY=${SECRET_KEY}
JWT_SECRET_KEY=${JWT_SECRET_KEY}

# ============= URLS =============
# Staging frontend and backend URLs
FRONTEND_URL=https://staging.voxquery.com
BACKEND_URL=https://api-staging.voxquery.com

# ============= LOGGING =============
LOG_LEVEL=INFO

# ============= FEATURES =============
# Production-like configuration
DEBUG=false
ALLOW_CORS=false
ALLOW_INTROSPECTION=false

# ============= OPTIONAL =============
# Observability
DATADOG_API_KEY=${DATADOG_API_KEY}
SENTRY_DSN=${SENTRY_DSN}

# ============= DATABASE SETTINGS =============
# Connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# Query limits
MAX_ROWS_RETURNED=10000
MAX_EXECUTION_TIME_SECONDS=30
MAX_REQUEST_SIZE=10485760

# ============= REDIS SETTINGS =============
REDIS_TTL_DEFAULT=3600
REDIS_MAX_MEMORY=256mb

# ============= RATE LIMITING =============
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=5000

# ============= CACHE SETTINGS =============
CACHE_TTL_CHEAP=3600
CACHE_TTL_MODERATE=300
CACHE_TTL_EXPENSIVE=60

# ============= SECURITY SETTINGS =============
REQUIRE_HTTPS=true
HSTS_MAX_AGE=31536000
SESSION_TIMEOUT_MINUTES=480

# ============= NOTES =============
# Staging should mirror Production as closely as possible
# All values marked ${VARIABLE} should be set in Render dashboard
# NEVER commit actual secrets to this file
# Review all settings with security checklist before deploying to production
